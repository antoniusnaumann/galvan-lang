type Dog {
    name: String
    age: Int
}

test "Create struct" {
    let dog = Dog(name: "Rex", age: 3)
    assert dog.name == "Rex"
    assert dog.age == 3
}

fn shout_name(self: Dog) -> String {
    self.name.to_uppercase()
}

test "Call method" {
    let dog = Dog(name: "Rex", age: 3)
    assert dog.shout_name() == "REX"
}

fn happy_birthday(mut self: Dog) {
    self.age = self.age + 1
}

test "Call method with mutation" {
    mut dog = Dog(name: "Rex", age: 3)
    dog.mut.happy_birthday()
    (mut dog).happy_birthday()
    happy_birthday(mut dog)
    assert dog.age == 6
}

fn replace(ref self: Dog, replacement: Dog) {
    self = replacement
}

test "Call ref self method" {
    ref dog = Dog(name: "Rex", age: 3)
    dog.ref.replace(Dog(name: "Bello", age: 4))
    assert dog.name == "Bello"
    assert dog.age == 4

    (ref dog).replace(Dog(name: "Hasso", age: 5))
    assert dog.name == "Hasso"
    assert dog.age == 5

    replace(ref dog, Dog(name: "Lassie", age: 6))
    assert dog.name == "Lassie"
    assert dog.age == 6
}

test "Mutate struct fields through mut and ref variables" {
    mut mut_dog = Dog(name: "Rex", age: 3)
    mut_dog.name = "Bello"
    mut_dog.age = 4
    assert mut_dog.name == "Bello"
    assert mut_dog.age == 4

    ref ref_dog = Dog(name: "Hasso", age: 5)
    ref_dog.name = "Lassie"
    ref_dog.age = 6
    assert ref_dog.name == "Lassie"
    assert ref_dog.age == 6
}

fn new_dog(name: String) -> Dog {
    Dog(name: name, age: 0)
}

test "Construct from borrowed parameters" {
    let dog = new_dog("Hasso")
    assert dog.name == "Hasso"
    assert dog.age == 0
}

type Book {
    title: String = "Field Notes"
    content: String = "No notes yet"
}

test "Structs with default fields" {
    let book = Book()
    assert book.title == "Field Notes"
    assert book.content == "No notes yet"
}

test "Structs with some default fields" {
    let book = Book(content: "Packed lunch at noon")
    assert book.title == "Field Notes"
    assert book.content == "Packed lunch at noon"
}
