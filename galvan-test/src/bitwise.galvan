test "Bitwise or" {
    assert 5 | 3 == 7
}

test "Bitwise and" {
    assert 6 & 3 == 2
}

test "Bitwise xor" {
    assert 5 ~ 3 == 6
}

test "Bitwise left shift" {
    assert 1 << 4 == 16
}

test "Bitwise right shift" {
    assert 16 >> 3 == 2
}

test "Bitwise operator precedence" {
    assert 1 | 2 & 3 == 3
    assert 1 ~ 3 & 1 == 0
    assert 1 << 2 + 1 == 8
}
